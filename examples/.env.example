# ============================================
# Hermes WebUI Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# --- Agent Directory ---
HERMES_WEBUI_AGENT_DIR=D:\hermes-windows-native\hermes-agent

# --- Python Path (use Agent's venv) ---
HERMES_WEBUI_PYTHON=D:\hermes-windows-native\hermes-agent\.venv\Scripts\python.exe

# --- WebUI Port ---
HERMES_WEBUI_PORT=8787

# --- State Storage ---
HERMES_WEBUI_STATE_DIR=D:\hermes-windows-native\hermes-webui\state

# --- Kimi API Key (for chat) ---
KIMI_API_KEY=sk-your-kimi-api-key-here

# --- LM Studio API Key (for vision/text, default is fine) ---
LM_STUDIO_API_KEY=lm-studio
