# ============================================================
# Hermes Windows Native - 完整配置示例
# ============================================================
#
# 使用方法:
#   1. 复制此文件为 config.yaml
#      cp examples/config.yaml.example ~/.hermes/config.yaml
#   2. 根据下方注释修改配置项
#   3. 敏感信息（API Key）建议通过 .env 文件设置
#
# 配置优先级: 环境变量 > .env > config.yaml
#
# 详细配置说明:
#   - 聊天模型: docs/zh-CN/configuration/chat-config.md
#   - 视觉模型: docs/zh-CN/configuration/vision-config.md
#   - 语音转写: docs/zh-CN/configuration/audio-config.md
#   - 文本处理: docs/zh-CN/configuration/text-config.md
# ============================================================

# ----------------------------------------------------------
# 一、主模型配置 (Chat 模式)
# ----------------------------------------------------------
# 用于纯文本对话、代码编写、问题解答
# 默认使用 Kimi K2.6 云端 API
model:
  # 模型 ID (必填)
  # 可选值:
  #   kimi-k2.6           -- 最新版 (推荐)
  #   kimi-k2.5           -- 稳定版
  #   moonshot-v1-8k      -- V1 旧版 (8K 上下文)
  #   moonshot-v1-32k     -- V1 长上下文 (32K)
  default: "kimi-k2.6"

  # 提供商标识 (必填)
  # 可选值:
  #   kimi-coding         -- Moonshot AI (用于 Kimi 系列)
  #   openai-codex        -- OpenAI (用于 GPT 系列)
  #   anthropic           -- Anthropic (用于 Claude 系列)
  #   gemini             -- Google (用于 Gemini 系列)
  #   custom              -- 自定义 OpenAI 兼容 API
  provider: "kimi-coding"

  # API 基础 URL (必填)
  # 各提供商地址:
  #   Moonshot: https://api.moonshot.cn/v1
  #   OpenAI:   https://api.openai.com/v1
  #   Anthropic: https://api.anthropic.com/v1
  #   Google:   https://generativelanguage.googleapis.com/v1beta
  base_url: "https://api.moonshot.cn/v1"

  # 单次最大输出 Token 数 (可选, 默认 4096)
  # max_tokens: 4096

  # 上下文窗口大小 (可选, 通常自动检测)
  # context_length: 131072

  # 温度参数 (可选, 0-2, 越高越随机)
  # temperature: 0.7

# ----------------------------------------------------------
# 二、辅助服务配置 (Auxiliary Services)
# ----------------------------------------------------------
# 用于图片识别、语音转写、文件处理
# 支持本地推理 + 云端 API 混合模式
auxiliary:
  # --------------------------------------------------------
  # 2.1 视觉模型 (Vision) -- 图片识别、截图分析
  # --------------------------------------------------------
  # 触发条件: 上传 .png/.jpg/.jpeg/.gif/.webp 文件
  # 推荐使用本地模型保护隐私
  vision:
    # 提供商 (必填)
    # 可选值:
    #   lmstudio            -- LM Studio (推荐, 本地)
    #   ollama              -- Ollama (本地)
    #   custom              -- 自定义 OpenAI 兼容 API
    #   openai-codex        -- OpenAI GPT-4V (云端)
    provider: "lmstudio"

    # 模型名称 (必填, 与 LM Studio 中显示的名称一致)
    # LM Studio 搜索关键词: glm-4.6v-flash
    # 推荐量化版本:
    #   glm-4.6v-flash:q5  -- 5-bit 量化 (精度高, 推荐 8GB+ 显存)
    #   glm-4.6v-flash:q4  -- 4-bit 量化 (省显存, 推荐 6GB 显存)
    #   glm-4.6v-flash:fp16 -- 无量化 (最高精度, 需要 12GB+ 显存)
    model: "glm-4.6v-flash:q4"

    # API 地址 (LM Studio 默认端口)
    base_url: "http://127.0.0.1:1234/v1"

    # API Key (LM Studio 本地通常不需要, 留空即可)
    api_key: ""

    # 超时时间 (秒)
    timeout: 30

    # 下载超时 (秒, 用于大图片)
    download_timeout: 30

    # 温度 (可选, 视觉任务建议较低温度保证准确性)
    temperature: 0.1

    # 最大 Token 数
    max_tokens: 2000

  # --------------------------------------------------------
  # 2.2 语音转写 (Audio / STT) -- 语音消息转文字
  # --------------------------------------------------------
  # 触发条件: 上传 .mp3/.wav/.m4a/.ogg 文件或录音
  # 使用 faster-whisper 本地引擎
  audio:
    # 引擎类型 (固定为 local)
    provider: "local"

    # 引擎名称 (固定为 faster-whisper)
    engine: "faster-whisper"

    # 模型大小 (影响精度和速度)
    # 可选值 (按推荐顺序):
    #   base     -- ~142MB, 速度与精度的最佳平衡点 ⭐ 推荐
    #   small    -- ~466MB, 更高精度
    #   tiny     -- ~75MB, 最快但精度低
    #   medium   -- ~1.5GB, 不推荐 (性价比低)
    #   large-v3 -- ~3GB, 最高精度 (需 10GB+ 显存)
    #   turbo    -- ~1.5GB, 优化速度
    model: "base"

    # 语言代码 (可选, 留空 = 自动检测)
    # 常用值: zh(中文), en(英文), ja(日文), ko(韩文)
    language: ""

    # 运行设备 (可选)
    # 可选值: auto(自动检测), cuda(GPU加速), cpu(CPU推理)
    device: "auto"

    # 计算类型 (可选, 影响 GPU 内存占用)
    # GPU 推荐: float16 (速度快, 精度几乎无损)
    # CPU 推荐: int8 (最省内存)
    # 可选值: float32, float16, int8
    compute_type: "auto"

    # 超时时间 (秒)
    timeout: 120

  # --------------------------------------------------------
  # 2.3 文本处理 (Text) -- 文件摘要、代码阅读
  # --------------------------------------------------------
  # 触发条件: 上传 .md/.py/.js/.txt/.json 等文本文件
  # 复用视觉模型 (GLM-4.6V)
  text:
    # 提供商 (同 vision 配置)
    provider: "lmstudio"

    # 模型名称 (同 vision 配置)
    model: "glm-4.6v-flash:q4"

    # API 地址
    base_url: "http://127.0.0.1:1234/v1"

    # API Key
    api_key: ""

    # 超时时间 (秒)
    timeout: 120

    # 单文件最大字符数 (超过会截断)
    max_file_chars: 50000

    # 温度 (文本理解可稍高)
    temperature: 0.5

    # 最大 Token 数 (文件分析可能需要较长输出)
    max_tokens: 8000

  # --------------------------------------------------------
  # 2.4 Web 内容提取 (可选)
  # --------------------------------------------------------
  # 用于从 URL 提取网页内容
  web_extract:
    provider: "lmstudio"
    model: "glm-4.6v-flash:q4"
    base_url: "http://127.0.0.1:1234/v1"
    timeout: 60

# ----------------------------------------------------------
# 三、WebUI 服务配置
# ----------------------------------------------------------
webui:
  # 监听端口 (默认 8787)
  # 如被占用可修改: 8788, 8000, 3000 等
  port: 8787

  # 绑定地址
  # 127.0.0.1 -- 仅本机访问 (推荐, 安全)
  # 0.0.0.0   -- 局域网可访问 (需设置密码)
  host: "127.0.0.1"

  # 状态数据存储目录
  # 存放会话历史、用户偏好等
  state_dir: "./state"

  # 助手显示名称 (在聊天界面中展示)
  bot_name: "Hermes"

  # 访问密码 (可选, 设置后需要登录才能使用)
  # 生产环境强烈建议设置!
  # password: "change-me-to-something-strong"

# ----------------------------------------------------------
# 四、记忆系统配置 (Memory System)
# ----------------------------------------------------------
memory:
  # 记忆存储方式
  # 可选值: sqlite (默认, 轻量级), json, redis
  store_type: "sqlite"

  # SQLite 数据库路径 (相对或绝对路径)
  db_path: "~/.hermes/memory/memory.db"

  # 最大记忆条目数 (超出自动清理旧记录)
  max_entries: 1000

  # 会话过期时间 (天, 超过自动归档)
  session_ttl_days: 30

# ----------------------------------------------------------
# 五、工具调用配置 (Tool Use)
# ----------------------------------------------------------
tools:
  # 是否启用终端命令执行
  terminal_enabled: true

  # 是否启用浏览器自动化
  browser_enabled: false  # 默认关闭, 需要额外安装

  # 是否启用文件操作
  file_operations_enabled: true

  # 工具调用最大并发数
  max_concurrent_tools: 3

  # 单次工具执行超时 (秒)
  tool_timeout: 60

# ----------------------------------------------------------
# 六、日志配置 (Logging)
# ----------------------------------------------------------
logging:
  # 日志级别
  # 可选值: DEBUG, INFO, WARNING, ERROR, CRITICAL
  level: "INFO"

  # 日志输出位置
  # console -- 输出到控制台
  # file   -- 写入日志文件
  # both   -- 同时输出到两者
  output: "both"

  # 日志文件路径
  file_path: "~/.hermes/logs/agent.log"

  # 单个日志文件最大大小 (MB)
  max_file_size_mb: 10

  # 保留的日志文件数量
  backup_count: 5

# ------------------------------------------------==========
# 七、高级配置 (Advanced)
# ----------------------------------------------------------

# 代理设置 (国内用户可能需要)
# proxy:
#   http: "http://127.0.0.1:7890"   # HTTP 代理
#   https: "http://127.0.0.1:7890"  # HTTPS 代理
#   no_proxy: "localhost,127.0.0.1"  # 不走代理的地址

# 并发请求限制
# rate_limiting:
#   requests_per_minute: 60  # 每分钟最大请求数
#   tokens_per_minute: 10000 # 每分钟最大 Token 数

# 安全设置
# security:
#   allowed_origins: ["http://127.0.0.1:8787"]  # 允许的来源
#   cors_enabled: true                               # 启用 CORS
#   rate_limit_by_ip: true                           # 按 IP 限流

# ============================================================
# 八、完整配置示例组合
# ============================================================

## 组合 A: 全云端 (简单快速, 有隐私风险)
# model:
#   default: "kimi-k2.6"
#   provider: "kimi-coding"
#   base_url: "https://api.moonshot.cn/v1"
# auxiliary:
#   vision:
#     provider: "openai-codex"
#     model: "gpt-4o-mini"
#     base_url: "https://api.openai.com/v1"
#   audio:
#     provider: "custom"
#     engine: "whisper-api"
#     model: "whisper-1"

## 组合 B: 全本地 (隐私安全, 需要硬件)
# auxiliary:
#   vision:
#     provider: "lmstudio"
#     model: "glm-4.6v-flash:q4"
#     base_url: "http://127.0.0.1:1234/v1"
#   audio:
#     provider: "local"
#     engine: "faster-whisper"
#     model: "base"
#     device: "cuda"

## 组合 C: 混合模式 (推荐, 平衡成本和隐私) ← 当前默认配置
# Chat → 云端 (Kimi K2.6)
# Vision → 本地 (GLM-4.6V)
# Audio → 本地 (Whisper)
# Text → 本地 (GLM-4.6V)

# ============================================================
# END OF CONFIGURATION EXAMPLE
# ============================================================
